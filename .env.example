# Public Supabase URL (safe to expose only with correct RLS policies)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase publishable key used by browser clients
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only key. Never prefix this variable with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only YouTube Data API key used to suggest albums and tracks.
# Add it in Vercel; never expose it as NEXT_PUBLIC_ or commit it.
YOUTUBE_API_KEY=
